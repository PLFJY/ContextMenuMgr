<UserControl
    x:Class="ContextMenuMgr.Frontend.Views.SettingsPageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <WrapPanel Margin="10,10,0,0" Orientation="Horizontal">
            <Border
                Margin="0,0,10,10"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="{Binding LanguageLabel}" />
                    <ComboBox
                        Width="220"
                        Margin="0,12,0,0"
                        DisplayMemberPath="DisplayName"
                        ItemsSource="{Binding AvailableLanguages}"
                        SelectedItem="{Binding SelectedLanguage}" />
                </StackPanel>
            </Border>

            <Border
                Margin="0,0,10,10"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="{Binding ThemeLabel}" />
                    <ComboBox
                        Width="220"
                        Margin="0,12,0,0"
                        DisplayMemberPath="DisplayName"
                        ItemsSource="{Binding AvailableThemes}"
                        SelectedItem="{Binding SelectedTheme}" />
                </StackPanel>
            </Border>

            <Border
                Margin="0,0,10,10"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="{Binding LogLevelLabel}" />
                    <ComboBox
                        Width="220"
                        Margin="0,12,0,0"
                        DisplayMemberPath="DisplayName"
                        ItemsSource="{Binding AvailableLogLevels}"
                        SelectedItem="{Binding SelectedLogLevel}" />
                </StackPanel>
            </Border>

            <Border
                Margin="0,0,10,10"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="{Binding StartupBehaviorTitle}" />
                    <CheckBox
                        Margin="0,12,0,0"
                        Content="{Binding LaunchMinimizedLabel}"
                        IsChecked="{Binding StartMinimized}" />
                    <TextBlock
                        Margin="0,8,0,0"
                        Opacity="0.72"
                        Text="{Binding LaunchMinimizedDescription}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border
                Margin="0,0,10,10"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="{Binding ProtectionTitle}" />
                    <ui:ToggleSwitch
                        Margin="0,12,0,0"
                        Content="{Binding LockNewContextMenuItemsLabel}"
                        IsChecked="{Binding LockNewContextMenuItems, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock
                        Margin="0,8,0,0"
                        Opacity="0.72"
                        Text="{Binding LockNewContextMenuItemsDescription}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border
                Margin="0,0,10,10"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="{Binding ServiceSettingsTitle}" />
                    <TextBlock
                        Margin="0,10,0,0"
                        Opacity="0.72"
                        Text="{Binding ServiceStateText}" />
                    <WrapPanel Margin="0,16,0,0">
                        <ui:Button
                            Margin="0,0,12,12"
                            Padding="16,8"
                            Command="{Binding InstallOrRepairServiceCommand}"
                            Content="{Binding InstallOrRepairServiceText}"
                            Icon="{ui:SymbolIcon Symbol=ArrowDownload24}" />
                        <Grid Margin="0,0,12,12">
                            <ui:Flyout
                                Margin="0,0,0,25"
                                IsOpen="{Binding IsUninstallFlyoutOpen, Mode=TwoWay}"
                                Placement="Top">
                                <StackPanel Width="300">
                                    <TextBlock
                                        HorizontalAlignment="Left"
                                        Text="{Binding UninstallFlyoutText}"
                                        TextWrapping="Wrap" />
                                    <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                        <ui:Button
                                            Margin="0,0,8,0"
                                            Appearance="Primary"
                                            Command="{Binding ConfirmUninstallServiceCommand}"
                                            Content="{Binding ConfirmUninstallText}"
                                            Icon="{ui:SymbolIcon Symbol=Delete24}" />
                                        <ui:Button
                                            Appearance="Secondary"
                                            Command="{Binding CloseUninstallFlyoutCommand}"
                                            Content="{Binding CancelText}"
                                            Icon="{ui:SymbolIcon Symbol=Dismiss24}" />
                                    </StackPanel>
                                </StackPanel>
                            </ui:Flyout>
                            <ui:Button
                                Padding="16,8"
                                Command="{Binding OpenUninstallServiceFlyoutCommand}"
                                Content="{Binding UninstallServiceText}"
                                Icon="{ui:SymbolIcon Symbol=Delete24}" />
                        </Grid>
                        <Button
                            Margin="0,0,12,12"
                            Padding="16,8"
                            Command="{Binding RefreshServiceStateCommand}"
                            Content="{Binding RefreshText}" />
                        <ui:Button
                            Margin="0,0,12,12"
                            Padding="16,8"
                            Command="{Binding RestartExplorerCommand}"
                            Content="{Binding RestartExplorerText}"
                            Icon="{ui:SymbolIcon Symbol=ArrowSync24}" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border
                Margin="0,0,10,10"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="{Binding LocalFilesTitle}" />
                    <WrapPanel Margin="0,16,0,0">
                        <ui:Button
                            Margin="0,0,12,12"
                            Padding="16,8"
                            Command="{Binding OpenLogsFolderCommand}"
                            Content="{Binding OpenLogsFolderText}"
                            Icon="{ui:SymbolIcon Symbol=DocumentText24}" />
                        <ui:Button
                            Margin="0,0,12,12"
                            Padding="16,8"
                            Command="{Binding OpenStateFolderCommand}"
                            Content="{Binding OpenStateFolderText}"
                            Icon="{ui:SymbolIcon Symbol=Database24}" />
                        <ui:Button
                            Margin="0,0,12,12"
                            Padding="16,8"
                            Command="{Binding OpenConfigFolderCommand}"
                            Content="{Binding OpenConfigFolderText}"
                            Icon="{ui:SymbolIcon Symbol=Settings24}" />
                    </WrapPanel>
                </StackPanel>
            </Border>
        </WrapPanel>
    </ScrollViewer>
</UserControl>
